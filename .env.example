# Production sozlamalari uchun nusxa oling: cp .env.example .env
# So'ngra quyidagi qiymatlarni o'zgartiring va docker compose up -d --build

# PostgreSQL paroli (kuchli, tasodifiy parol qo'ying)
POSTGRES_PASSWORD=change_me_strong_password

# Streamlit dashboard kirish paroli
DASHBOARD_PASSWORD=change_me_dashboard_password

# Email alert (ixtiyoriy) — diabetes_risk >= 0.8 bo'lgan bemorlar uchun
# Bo'sh qoldirilsa, alert yuborilmaydi (faqat log yoziladi)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
